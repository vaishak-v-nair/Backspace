{
  "name": "backspace-timeline",
  "displayName": "Backspace Timeline",
  "description": "Visual timeline for AI-driven code changes — scrub through snapshots captured by the Backspace CLI.",
  "version": "0.1.0",
  "publisher": "backspace",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "backspace.openTimeline",
        "title": "Backspace: Open Timeline",
        "icon": "$(history)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "backspace",
          "title": "Backspace",
          "icon": "$(history)"
        }
      ]
    },
    "views": {
      "backspace": [
        {
          "type": "webview",
          "id": "backspace.timelineView",
          "name": "Timeline"
        }
      ]
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --external:better-sqlite3 --format=cjs --platform=node --sourcemap",
    "watch": "npm run build -- --watch",
    "lint": "tsc --noEmit",
    "package": "vsce package"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  }
}
