{
  "name": "backspace-ai",
  "version": "0.1.0",
  "description": "Recovery intelligence for AI-assisted coding — track every AI file change as sessions, score risk, revert atomically.",
  "type": "module",
  "license": "MIT",
  "author": "Vaishak V Nair (https://github.com/vaishak-v-nair)",
  "homepage": "https://github.com/vaishak-v-nair/Backspace#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vaishak-v-nair/Backspace.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/vaishak-v-nair/Backspace/issues"
  },
  "keywords": [
    "ai",
    "claude",
    "cursor",
    "aider",
    "copilot",
    "mcp",
    "rollback",
    "revert",
    "snapshot",
    "provenance",
    "recovery",
    "developer-tools",
    "cli"
  ],
  "bin": {
    "backspace-ai": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist",
    "smoke": "node scripts/smoke.mjs",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "better-sqlite3": "^11.10.0",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "diff": "^9.0.0",
    "ignore": "^7.0.0",
    "ora": "^8.1.0",
    "prompts": "^2.4.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^7.0.2",
    "@types/node": "^22.0.0",
    "@types/prompts": "^2.4.9",
    "rimraf": "^5.0.7",
    "tsup": "^8.1.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
